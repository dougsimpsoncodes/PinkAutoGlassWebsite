# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# build test script
test-build.js

# Security - prevent committing secrets
**/client_secret*.json
**/credentials*.json
**/*AUDIT*.md
*COMPREHENSIVE*.md
*SECRET*.md
**/*.key
**/*.pem
**/*.p12
**/*.pfx

# Keep assets directory but ignore sensitive files
!assets/
assets/**/client_secret*.json
assets/**/credentials*.json
.env*.local

# Google Search Console exports
*.zip

# Stashed migrations (not ready for production)
.stashed-migrations/

# Playwright MCP logs
.playwright-mcp/

# Root-level screenshots and reports
/*.png
/*.csv

# Financial exports and temp files
/*.xlsx
/tmp/
supabase/.temp/

# Review response skill — audit log contains customer PII (names, phones,
# addresses, vehicle details). Log stays local only; never commit to git history.
.claude/skills/review-response/review_responses_drafted.jsonl

# Customer PII — never commit drafted/raw review data
.claude/skills/review-response/review_responses_drafted.jsonl

# Customer PII — RingCentral pilot artifacts (call recordings, transcripts,
# customer-identifying CSVs). Live in ~/clients/pink-auto-glass/private/ instead.
# Codex code review flagged this as P0 on 2026-05-26.
analysis/

# Destructive automation scripts — these auto-modify OTHER satellite repos
# (next.config rewrites, repo-wide git add/checkout). Run them deliberately
# from outside the repo; do not commit and risk accidental CI invocation.
# Codex code review flagged these as P1 on 2026-05-26.
scripts/apply-satellite-fixes.sh
scripts/apply-satellite-snippet-rewrites.sh
