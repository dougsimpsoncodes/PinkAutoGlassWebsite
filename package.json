{
  "name": "pink-auto-glass-demo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:watch": "nodemon --watch .env.local --watch .env --exec 'rm -rf .next && next dev'",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "generate-brand": "node assets/scripts/generate-brand-images.mjs",
    "oauth:gsc": "node scripts/exchange-google-oauth-code.mjs gsc",
    "oauth:ads": "node scripts/exchange-google-oauth-code.mjs ads",
    "oauth:gbp": "node scripts/exchange-google-oauth-code.mjs gbp",
    "oauth:gsc:verify": "node scripts/verify-google-search-console-auth.mjs",
    "verify:brands": "./scripts/verify-brand-urls.sh",
    "verify:schema": "node scripts/validate-schema.js",
    "ci:guard:ad-platform": "node scripts/ci/guard-no-bing.js",
    "ci:guard:mygrant": "tsx scripts/verify-mygrant-client.ts",
    "ci:guard:autobolt": "tsx scripts/verify-autobolt-client.ts",
    "ci:guard:pricing": "tsx scripts/verify-pricing-markup.ts",
    "ci:guard:nags-compat": "tsx scripts/verify-nags-compatibility.ts",
    "ci:guard:scoring": "tsx scripts/verify-mygrant-scoring.ts",
    "ci:guard:pricing-builder": "tsx scripts/verify-pricing-builder.ts",
    "ci:guard:schedule-slots": "tsx scripts/verify-schedule-slots.ts",
    "ci:guard:env-coherence": "tsx scripts/verify-env-coherence.ts",
    "ci:guard:adas-tier": "tsx scripts/verify-adas-tier.ts",
    "ci:guard:quote-telemetry": "tsx scripts/verify-quote-telemetry-isolation.ts",
    "ci:guards": "npm run ci:guard:ad-platform && npm run ci:guard:mygrant && npm run ci:guard:autobolt && npm run ci:guard:pricing && npm run ci:guard:nags-compat && npm run ci:guard:scoring && npm run ci:guard:pricing-builder && npm run ci:guard:schedule-slots && npm run ci:guard:env-coherence && npm run ci:guard:adas-tier && npm run ci:guard:quote-telemetry",
    "env:pull": "vercel env pull .env.local && sed -i '' 's/\\\\n\"/\"/g' .env.local && echo '✓ .env.local pulled and sanitized (no \\n)'",
    "postinstall": "git config core.hooksPath .git-hooks 2>/dev/null || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.67.0",
    "@google-analytics/data": "^5.2.1",
    "@google/generative-ai": "^0.24.1",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@radix-ui/react-accordion": "1.1.2",
    "@radix-ui/react-dialog": "1.0.5",
    "@radix-ui/react-select": "2.0.0",
    "@radix-ui/react-tabs": "1.0.4",
    "@ringcentral/sdk": "^5.0.5",
    "@sendgrid/mail": "^8.1.6",
    "@supabase/supabase-js": "^2.55.0",
    "@types/node": "20.10.4",
    "@types/uuid": "^10.0.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/kv": "^3.0.0",
    "@vercel/postgres": "^0.10.0",
    "adm-zip": "^0.5.16",
    "autoprefixer": "10.4.16",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "0.7.0",
    "clsx": "2.0.0",
    "csv-parse": "^6.1.0",
    "date-fns": "^4.1.0",
    "exceljs": "^4.4.0",
    "google-ads-api": "^21.0.1",
    "googleapis": "^164.1.0",
    "jsonrepair": "^3.13.2",
    "lucide-react": "0.294.0",
    "next": "^15.5.10",
    "next-themes": "^0.4.6",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "postcss": "^8.5.10",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recharts": "^3.3.0",
    "resend": "^6.3.0",
    "sharp": "0.33.1",
    "tailwind-merge": "2.2.0",
    "tailwindcss": "3.3.6",
    "twilio": "^5.10.4",
    "typescript": "5.3.3",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/adm-zip": "^0.5.7",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.2.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.0.4",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.6"
  },
  "overrides": {
    "@typescript-eslint/parser": "^8.59.2",
    "@typescript-eslint/typescript-estree": "^8.59.2",
    "postcss": "^8.5.10",
    "uuid": "$uuid"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
