{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-google-ads",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/sync-bing-ads",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/sync-search-console",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/sync-ringcentral",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/run-attribution",
      "schedule": "0 3 * * *"
    }
  ]
}
